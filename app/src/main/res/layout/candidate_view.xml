<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="45dp"
    android:orientation="horizontal"
    android:background="#F0F0F0"
    android:gravity="center_vertical">

    <!-- TOOLBAR CONTAINER -->
    <!-- Groups all icons so they can be hidden during typing -->
    <LinearLayout
        android:id="@+id/toolbar_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- PERMANENT GRID MENU BUTTON (Left-most, never hides) -->
        <ImageButton
            android:id="@+id/btn_grid_menu"
            android:layout_width="45dp"
            android:layout_height="match_parent"
            android:src="@drawable/grid_menu_24px"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="#5F6368"
            android:contentDescription="Grid Menu" />

        <!-- DYNAMIC ACTIVE TOOLS CONTAINER -->
        <!-- ImageButtons will be dynamically inflated, styled, and appended here by BubbleKeyboardService -->
        <LinearLayout
            android:id="@+id/active_tools_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal" />

        <!-- Vertical Separator Line -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#CCCCCC" />
            
    </LinearLayout>

    <!-- SCROLLABLE SUGGESTIONS AREA -->
    <HorizontalScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none"
        android:fadingEdge="horizontal">

        <LinearLayout
            android:id="@+id/candidate_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="5dp"
            android:paddingEnd="5dp">

            <!-- Suggestions added dynamically -->

        </LinearLayout>

    </HorizontalScrollView>

</LinearLayout>