<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="45dp"
    android:orientation="horizontal"
    android:background="#F0F0F0"
    android:gravity="center_vertical">

    <!-- TOOLBAR CONTAINER -->
    <!-- Groups all icons so they can be hidden during typing -->
    <LinearLayout
        android:id="@+id/toolbar_container"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- CLIPBOARD BUTTON (Updated to content_paste_24px) -->
        <ImageButton
            android:id="@+id/btn_clipboard"
            android:layout_width="45dp"
            android:layout_height="match_parent"
            android:src="@drawable/content_paste_24px"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="#5F6368"
            android:contentDescription="Clipboard History" />

        <!-- KEYBOARD SWITCHER BUTTON (Updated to change_circle_24px) -->
        <ImageButton
            android:id="@+id/btn_keyboard_switch"
            android:layout_width="45dp"
            android:layout_height="match_parent"
            android:src="@drawable/change_circle_24px"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="#5F6368"
            android:contentDescription="Switch Keyboard" />

        <!-- TRANSLATE BUTTON (Updated to g_translate_24px) -->
        <ImageButton
            android:id="@+id/btn_translate"
            android:layout_width="45dp"
            android:layout_height="match_parent"
            android:src="@drawable/g_translate_24px"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="#5F6368"
            android:contentDescription="Translate" />

        <!-- DIRECT TRANSLATE GLOBE BUTTON (Updated to electric_bolt_24px) -->
        <ImageButton
            android:id="@+id/btn_direct_translate"
            android:layout_width="45dp"
            android:layout_height="match_parent"
            android:src="@drawable/electric_bolt_24px"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="#5F6368"
            android:contentDescription="Direct Translate" />

        <!-- BUBBLE LAUNCHER BUTTON (Updated to bubble_24px) -->
        <ImageButton
            android:id="@+id/btn_bubble_launcher"
            android:layout_width="45dp"
            android:layout_height="match_parent"
            android:src="@drawable/bubble_24px"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="#5F6368"
            android:contentDescription="Show Bubble" />

        <!-- OCR COPY BUTTON (Updated to select_all_24px) -->
        <ImageButton
            android:id="@+id/btn_ocr_copy"
            android:layout_width="45dp"
            android:layout_height="match_parent"
            android:src="@drawable/select_all_24px"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="#5F6368"
            android:contentDescription="OCR Copy" />

        <!-- NEW: SCANNER BUTTON (Updated to document_scanner_24px) -->
        <ImageButton
            android:id="@+id/btn_scanner"
            android:layout_width="45dp"
            android:layout_height="match_parent"
            android:src="@drawable/document_scanner_24px" 
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="#5F6368"
            android:contentDescription="Scanner" />

        <!-- AUTO SAVE BUTTON (Updated to save_24px) -->
        <ImageButton
            android:id="@+id/btn_autosave"
            android:layout_width="45dp"
            android:layout_height="match_parent"
            android:src="@drawable/save_24px"
            android:background="?android:attr/selectableItemBackground"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:tint="#5F6368"
            android:contentDescription="Auto Save Mode" />

        <!-- Vertical Separator Line -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#CCCCCC" />
            
    </LinearLayout>

    <!-- SCROLLABLE SUGGESTIONS AREA -->
    <HorizontalScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none"
        android:fadingEdge="horizontal">

        <LinearLayout
            android:id="@+id/candidate_container"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="5dp"
            android:paddingEnd="5dp">

            <!-- Suggestions added dynamically -->

        </LinearLayout>

    </HorizontalScrollView>

</LinearLayout>