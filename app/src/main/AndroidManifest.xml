<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.app.bubble">

    <!-- Normal / Special Permissions (Granted automatically at install-time) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Dangerous / Runtime Permissions (These will now successfully show up in App Info) -->
    <uses-permission android:name="android.permission.CAMERA" />
    
    <!-- Legacy Storage Permissions for Android 12 and below (API <= 32) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    
    <!-- Media Permissions for Android 13+ (API >= 33) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:icon="@drawable/bubble"
        android:label="bubble"
        android:roundIcon="@drawable/bubble"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light">

        <!-- Updated Metadata for ML Kit (New OCR Engine) -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="ocr" />

        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-2223803405403727~3540804071"/>

        <activity android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:label="Settings"
            android:theme="@style/Theme.AppCompat.Light" />

        <activity
            android:name=".HelpActivity"
            android:label="Help"
            android:theme="@style/Theme.AppCompat.Light" />

        <!-- NEW: Debug Activity Registration -->
        <activity
            android:name=".DebugActivity"
            android:label="Debug Mode"
            android:theme="@style/Theme.AppCompat.Light" />

        <!-- NEW: Transparent Activity for Gallery Selection -->
        <activity
            android:name=".GalleryActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false"
            android:launchMode="singleTop" />

        <!-- FIX: Added foregroundServiceType for Screen Capture support on Android 14 -->
        <service
            android:name=".FloatingTranslatorService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- Accessibility Service for Auto-Scrolling -->
        <service
            android:name=".GlobalScrollService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Input Method Service for the Keyboard Extension -->
        <service
            android:name=".BubbleKeyboardService"
            android:label="Bubble Keyboard"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Service for the Two-Line Overlay Logic -->
        <service
            android:name=".TwoLineOverlayService"
            android:enabled="true"
            android:exported="false" />

    </application>

</manifest>